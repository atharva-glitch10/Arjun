# Copy to .env.local and fill in. Never commit .env.local.

# --- Supabase (Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Bypasses RLS. Must never be exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- LLM: xAI (Grok), OpenAI-compatible API ---
XAI_API_KEY=your-xai-key
XAI_BASE_URL=https://api.x.ai/v1
# Run `npm run check:llm` after setting the key to list models you can actually call.
XAI_MODEL=grok-4-fast

# --- App ---
# Used as the magic-link redirect target.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Copy to .env.local and fill in. Never commit .env.local.

# --- Supabase (Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Bypasses RLS. Must never be exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- LLM: Groq (Qwen), OpenAI-compatible API. console.groq.com/keys ---
GROQ_API_KEY=your-groq-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Run `npm run check:llm` after setting the key: it lists the models you can actually call
# and checks that this one honours enforced structured output.
GROQ_MODEL=qwen/qwen3-32b

# --- App ---
# Used as the magic-link redirect target.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Voice (OPTIONAL stretch layer — the text loop must stand alone without it) ---
# ElevenLabs speech-to-speech. Server-only: the browser gets a short-lived signed URL,
# never this key. Leave blank until the core loop is proven.
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
